# v0.4.6 verification — clean container with claude + codex CLIs
# Mount ~/.claude, ~/.codex from host for auth reuse
FROM node:22-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
  git curl jq ca-certificates \
  && rm -rf /var/lib/apt/lists/*

# CLIs — codex pinned to 0.128.0 (호스트 검증 버전; 0.130.0 에서 hooks dispatch 회귀 의심)
RUN npm i -g @anthropic-ai/claude-code@latest @openai/codex@0.128.0 2>&1 | tail -5

WORKDIR /workspace

# forgen tarball (npm pack output: wooojin-forgen-X.Y.Z.tgz)
COPY wooojin-forgen-*.tgz /tmp/forgen.tgz
RUN npm i -g /tmp/forgen.tgz

# Verification script
COPY verify-v046.sh /workspace/verify-v046.sh
RUN chmod +x /workspace/verify-v046.sh

# Non-root user (claude --dangerously-skip-permissions refuses root)
# 호스트 uid 와 매칭하기 위해 build arg 로 uid 받음 (default 1000)
ARG HOST_UID=1000
ARG HOST_GID=1000
RUN if id -u node >/dev/null 2>&1; then userdel -r node 2>/dev/null || true; fi && \
    (groupadd -g $HOST_GID hostgrp 2>/dev/null || true) && \
    useradd -m -u $HOST_UID -g $HOST_GID -s /bin/bash node && \
    mkdir -p /home/node/.forgen /home/node/.codex /home/node/.claude && \
    chown -R $HOST_UID:$HOST_GID /workspace /home/node

USER node

# Test project (as node user)
RUN mkdir -p /workspace/test-project && cd /workspace/test-project && \
    git init -q && git config user.email "t@t.com" && git config user.name "t" && \
    npm init -y >/dev/null && echo '{}' > tsconfig.json

WORKDIR /workspace/test-project

ENTRYPOINT ["/workspace/verify-v046.sh"]
